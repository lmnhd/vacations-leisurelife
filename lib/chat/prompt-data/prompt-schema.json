{
  "schema_version": "1.0",
  "root": {
    "identity": {
      "name": "LL Cruise Buddy",
      "persona_ref": "skills/persona.md",
      "global_rules": [
        "Never fabricate cruise pricing",
        "Always confirm before collecting PII",
        "Use Agent Perks when it helps close"
      ]
    },
    "contexts": {
      "onboarding": {
        "priority": 1,
        "trigger": "new_user OR incomplete_profile",
        "available_tools": [
          "cruise_brothers_knowledge"
        ],
        "instructions": [
          "Build trust before requesting sensitive data",
          "Start with travel history, not personal info"
        ],
        "sub_contexts": {
          "cruise_experienced": {
            "trigger": "user_has_cruised == true",
            "instructions_ref": "skills/onboarding/cruise-review.md",
            "data_targets": [
              "preferences.vibe",
              "preferences.dining"
            ]
          },
          "cruise_novice": {
            "trigger": "user_has_cruised == false",
            "instructions_ref": "skills/onboarding/travel-review.md",
            "data_targets": [
              "preferences.vibe",
              "logistics.departure_port"
            ]
          }
        }
      },
      "fast_booking": {
        "priority": 2,
        "trigger": "user_requests_specific_cruise",
        "instructions_ref": "skills/booking/fast-flow.md",
        "available_tools": [
          "perplexity_cruise_research",
          "cruise_brothers_knowledge",
          "cruise_brothers_scraper"
        ],
        "required_data": [
          "travelers[0].legal_first_name",
          "financials.budget_per_person"
        ],
        "sub_contexts": {
          "info_collection": {
            "trigger": "required_data_incomplete",
            "instructions_ref": "skills/data-collection/pii-collection.md",
            "data_targets": [
              "travelers[0].legal_first_name",
              "financials.budget_per_person",
              "logistics.departure_port",
              "group.total_travelers"
            ]
          },
          "package_search": {
            "trigger": "required_data_complete",
            "instructions_ref": "skills/booking/package-search.md",
            "available_tools": [
              "perplexity_cruise_research",
              "cruise_brothers_knowledge",
              "excursion_finder",
              "cruise_brothers_scraper",
              "pricing_comparator"
            ],
            "data_targets": [
              "group.preferred_packages"
            ]
          },
          "package_presentation": {
            "trigger": "search_results_ready",
            "instructions_ref": "skills/booking/package-presentation.md",
            "available_tools": [
              "perplexity_cruise_research",
              "cruise_brothers_knowledge",
              "pricing_comparator"
            ]
          },
          "payment_handoff": {
            "trigger": "user_selects_package",
            "instructions_ref": "skills/data-collection/pii-collection.md",
            "data_targets": [
              "travelers[0].email",
              "financials.flex_pay_interested"
            ]
          }
        }
      },
      "cruise_review": {
        "priority": 5,
        "trigger": "user_discusses_past_cruise",
        "instructions_ref": "skills/review/past-cruise.md",
        "available_tools": [
          "social_media_insights"
        ]
      },
      "active_voyage": {
        "priority": 3,
        "trigger": "user_on_active_booking",
        "instructions_ref": "skills/voyage/onboard-assistant.md",
        "available_tools": [
          "cruise_brothers_knowledge",
          "excursion_finder"
        ]
      },
      "post_voyage": {
        "priority": 6,
        "trigger": "user_completed_cruise",
        "instructions_ref": "skills/voyage/post-cruise.md",
        "available_tools": [
          "cruise_brothers_knowledge"
        ]
      }
    }
  }
}