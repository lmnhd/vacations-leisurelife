{
  "tool_id": "social_media_insights",
  "display_name": "Social Media Cruise Insights",
  "description": "Analyze social review sentiment for cruise lines, ships, and destinations.",
  "handler": "lib/chat/tools/social-media-insights.ts",
  "available_in_contexts": [
    "onboarding.cruise_experienced",
    "cruise_review"
  ],
  "input_schema": {
    "cruise_line": "string",
    "ship_name": "string | null",
    "destination": "string | null"
  },
  "output_schema": {
    "common_highlights": "string[]",
    "common_complaints": "string[]",
    "sentiment_summary": "string"
  },
  "thoughts_stream_label": "Analyzing real cruise reviews..."
}
